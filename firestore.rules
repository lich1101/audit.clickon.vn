rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // MySQL/Laravel is the source of truth. These legacy data collections are
    // intentionally closed to clients so Firebase cannot become application storage.
    match /users/{document=**} {
      allow read, write: if false;
    }

    match /websites/{document=**} {
      allow read, write: if false;
    }

    match /websiteAudits/{document=**} {
      allow read, write: if false;
    }

    match /plans/{document=**} {
      allow read, write: if false;
    }

    match /creditLogs/{document=**} {
      allow read, write: if false;
    }

    match /auditRuns/{document=**} {
      allow read, write: if false;
    }

    match /auditRunItems/{document=**} {
      allow read, write: if false;
    }

    // Realtime transport only. Server writes a small signal; clients refetch
    // full audit data from Laravel/MySQL when this document changes.
    match /auditRunSignals/{runId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }
  }
}
