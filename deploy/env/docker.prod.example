COMPOSE_PROJECT_NAME=clickon-audit

# --- Publish cổng Nginx trong Docker (chọn MỘT cặp; xem docker.md) ---
#
# A) Chỉ Docker — VPS chỉ chạy stack này, HTTP công khai vào thẳng container:
#    (Tắt Apache/Nginx host trên cổng 80 nếu trùng.)
# NGINX_BIND=0.0.0.0
# NGINX_HTTP_PORT=80
#
# B) Máy chia sẻ — Nginx/Apache host giữ 80/443; stack chỉ listen localhost:
NGINX_BIND=127.0.0.1
NGINX_HTTP_PORT=18080

APP_NAME="Clickon Audit API"
APP_ENV=production
APP_KEY=base64:replace-me
APP_DEBUG=false
APP_URL=https://audit.clickon.vn/backend

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=clickon_audit
DB_USERNAME=clickon
DB_PASSWORD=change-db-password
MYSQL_ROOT_PASSWORD=change-root-password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.audit.clickon.vn

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=604800

CACHE_STORE=database
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@audit.clickon.vn
MAIL_FROM_NAME="Clickon Audit"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FRONTEND_URL=https://audit.clickon.vn
LARAVEL_INTERNAL_API_KEY=change-this-to-a-long-random-secret
LARAVEL_API_URL=http://api:8000
NEXT_PUBLIC_LARAVEL_API_URL=https://audit.clickon.vn/backend

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS=/var/www/html/storage/app/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/var/www/html/storage/app/firebase-service-account.json
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_DEFAULT_BUCKET=
FIREBASE_AUTH_TENANT_ID=

FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_TIMEOUT_SECONDS=180

# Provider/model chính riêng cho bước 2 và bước 3. Bỏ trống model để dùng model mặc định theo provider.
AUDIT_STEP2_AI_PROVIDER=openai
AUDIT_STEP2_AI_MODEL=
AUDIT_STEP3_AI_PROVIDER=openai
AUDIT_STEP3_AI_MODEL=
AUDIT_STEP3_FLOW_MODE=standard

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_DEEP_RESEARCH_AGENT=deep-research-pro-preview-12-2025
GEMINI_DEEP_RESEARCH_AGENTS=deep-research-pro-preview-12-2025,deep-research-preview-04-2026
GEMINI_TIMEOUT_SECONDS=180
# 0 = không giới hạn poll Deep Research (bước 2/3 khi dùng gemini_deep_research)
GEMINI_DEEP_RESEARCH_TIMEOUT_SECONDS=0

PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-deep-research

# Bước 2.5/3.5 ép raw output từ bước 2/3 về JSON. Chỉ dùng openai hoặc gemini.
AUDIT_STEP2_FORMATTER_PROVIDER=gemini
AUDIT_STEP2_FORMATTER_MODEL=gemini-2.5-flash
AUDIT_STEP3_FORMATTER_PROVIDER=gemini
AUDIT_STEP3_FORMATTER_MODEL=gemini-2.5-flash

AUDIT_MAX_CONTENT_CHARS=18000
AUDIT_MAX_CATEGORY_CONTENT_CHARS=7000
AUDIT_USE_JINA_READER=true
AUDIT_JINA_BASE_URL=https://r.jina.ai/
JINA_API_KEY=
AUDIT_USER_AGENT="ClickonAuditBot/1.0 (+https://audit.clickon.vn)"
AUDIT_FIRESTORE_SYNC=true
AUDIT_FIRESTORE_FALLBACK=false
# Bước 2 + 3 batch: 0 = không giới hạn (job queue, HTTP AI, lưu response, poll Deep Research)
AUDIT_BATCH_JOB_TIMEOUT_SECONDS=0
AUDIT_AI_HTTP_TIMEOUT_SECONDS=0
AUDIT_AI_HTTP_CONNECT_TIMEOUT_SECONDS=30
AUDIT_AI_HTTP_RETRY_ATTEMPTS=3
AUDIT_AI_HTTP_RETRY_SLEEP_MS=2000
AUDIT_MAX_AI_STEP_RESPONSE_BYTES=0
AUDIT_DEEP_RESEARCH_RESEARCH_PROVIDER=perplexity
AUDIT_DEEP_RESEARCH_RESEARCH_MODEL=sonar-deep-research
AUDIT_DEEP_RESEARCH_BATCH_SIZE=5
AUDIT_DEEP_RESEARCH_RESEARCH_REASONING_EFFORT=medium
AUDIT_DEEP_RESEARCH_RESEARCH_USE_ASYNC=true
AUDIT_DEEP_RESEARCH_ASYNC_TIMEOUT_SECONDS=900
AUDIT_DEEP_RESEARCH_ASYNC_POLL_INTERVAL_MS=3000
AUDIT_DEEP_RESEARCH_ASYNC_RETRY_ATTEMPTS=2
AUDIT_DEEP_RESEARCH_ASYNC_RETRY_SLEEP_MS=1500
AUDIT_DEEP_RESEARCH_REASONING_PROVIDER=openai
AUDIT_DEEP_RESEARCH_REASONING_MODEL=gpt-5.5
AUDIT_DEEP_RESEARCH_FORMATTER_PROVIDER=openai
AUDIT_DEEP_RESEARCH_FORMATTER_MODEL=gpt-5.5
AUDIT_CALLBACK_TIMEOUT_SECONDS=30
AUDIT_CALLBACK_RETRY_ATTEMPTS=3
AUDIT_CALLBACK_RETRY_SLEEP_MS=2000
QUEUE_WORKERS=3
DOCKER_PRUNE_AFTER_DEPLOY=1

# Giới hạn tài nguyên khi deploy/build trên VPS chia sẻ (quanlynoibo, winmap, ...)
COMPOSE_PARALLEL_LIMIT=1
NODE_BUILD_HEAP_MB=768
COMPOSER_MEMORY_LIMIT=512M
DEPLOY_NICE_LEVEL=10

ADMIN_SEED_EMAIL=admin@audit.clickon.vn
ADMIN_SEED_PASSWORD=ChangeMe123456!
ADMIN_SEED_NAME="Clickon Audit Admin"
# ADMIN_SEED_UID=
AUTO_SEED_ADMIN=1
